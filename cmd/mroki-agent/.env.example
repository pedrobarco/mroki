# Required: URLs for live and shadow services
MROKI_APP_LIVE_URL="https://httpbin.org/?mroki_gate=live"
MROKI_APP_SHADOW_URL="https://httpbin.org/?mroki_gate=shadow"

# Optional: Port for proxy server (default: 8080)
# MROKI_APP_PORT=8080

# Optional: Timeout for live requests (default: 5s)
# This timeout blocks client response, so keep it tight
# MROKI_APP_LIVE_TIMEOUT=5s

# Optional: Timeout for shadow requests (default: 10s)
# Shadow requests don't block client, so can be longer
# Useful if shadow service is slower (new version, debug mode, etc)
# MROKI_APP_SHADOW_TIMEOUT=10s
