# Server Configuration
MROKI_APP_PORT=8090

# API Authentication (required)
# Must be at least 16 characters long
# Used by agents to authenticate API requests via Bearer token
MROKI_APP_API_KEY=your-secret-key-minimum-16-chars

# CORS Configuration
# Comma-separated list of allowed origins for web UI (empty = CORS disabled)
# Example: http://localhost:5173,https://hub.example.com
MROKI_APP_CORS_ORIGINS=http://localhost:5173

# Security: Maximum request body size in bytes (default: 10MB)
# Protects against memory exhaustion attacks
# MROKI_APP_MAX_BODY_SIZE=10485760

# Server Timeouts
# Time to read the full request including body (default: 15s)
# MROKI_APP_READ_TIMEOUT=15s

# Time to write the response (default: 30s)
# MROKI_APP_WRITE_TIMEOUT=30s

# Keep-alive timeout for idle connections (default: 60s)
# MROKI_APP_IDLE_TIMEOUT=60s

# Database Configuration
MROKI_APP_DATABASE_URL=postgres://postgres:postgres@localhost:5432/mroki

# Connection Pool Configuration
# Maximum number of connections in the pool (default: 25)
MROKI_APP_DATABASE_MAX_CONNS=25

# Minimum number of connections to maintain in the pool (default: 5)
MROKI_APP_DATABASE_MIN_CONNS=5

# Maximum time a connection can remain idle before being closed (default: 5m)
MROKI_APP_DATABASE_MAX_CONN_IDLE=5m

# Maximum lifetime of a connection before it's closed and recreated (default: 1h)
MROKI_APP_DATABASE_MAX_CONN_LIFE=1h
