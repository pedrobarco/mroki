# mroki-proxy — Standalone Mode
# Diffs are printed to stdout. No database or API required.

# Required: service URLs
MROKI_APP_LIVE_URL=https://api.production.example.com
MROKI_APP_SHADOW_URL=https://api.shadow.example.com

# Optional: proxy settings
MROKI_APP_PORT=8080
MROKI_APP_SAMPLING_RATE=1.0
MROKI_APP_MAX_BODY_SIZE=10485760
MROKI_APP_LIVE_TIMEOUT=5s
MROKI_APP_SHADOW_TIMEOUT=10s

# Optional: max concurrent background shadow-comparison callbacks (default 200,
# 0 = unbounded). When the limit is reached, further shadow comparisons are
# dropped (logged as a warning) so the proxy never leaks goroutines under load;
# live traffic is unaffected.
# MROKI_APP_MAX_CONCURRENT_CALLBACKS=200

# Optional: outbound connection-pool tuning (0 = net/http default semantics)
# MROKI_APP_HTTP_CLIENT_MAX_IDLE_CONNS=100
# MROKI_APP_HTTP_CLIENT_MAX_IDLE_CONNS_PER_HOST=10
# MROKI_APP_HTTP_CLIENT_MAX_CONNS_PER_HOST=100
# MROKI_APP_HTTP_CLIENT_IDLE_CONN_TIMEOUT=90s

# Optional: shadow matching rules (comma-separated "ACTION METHOD:path", first match wins)
# Path patterns use Caddy "path" matcher semantics (case-insensitive): trailing "*" =
# recursive prefix (/admin/*), leading "*" = suffix (*.json), leading+trailing "*" =
# substring (*/admin/*), any other "*" = single segment. A bare "*" matches any path.
# Base rules denying POST/PUT/DELETE/PATCH are always appended as a catch-all;
# these rules are evaluated first and can override them per pattern.
# MROKI_APP_SHADOW_RULES=deny *:/health/*,allow POST:/api/v1/search

# Optional: field redaction (applied before diffing)
# MROKI_APP_REDACTED_FIELDS=headers.X-Internal-Token,body.user.password

# Optional: diff tuning
# MROKI_APP_DIFF_IGNORED_FIELDS=timestamp,created_at,updated_at
# MROKI_APP_DIFF_INCLUDED_FIELDS=user,order
# MROKI_APP_DIFF_FLOAT_TOLERANCE=0.001
