{
	admin off
	auto_https off
}

# Multi-gate configuration — shadow different backends per route
:8080 {
	# Shadow the users API
	route /api/users/* {
		mroki_gate {
			live https://api.production.example.com
			shadow https://api-v2.staging.example.com
		}
	}

	# Shadow the orders API with sampling, diff, and connection-pool tuning
	route /api/orders/* {
		mroki_gate {
			live https://orders.production.example.com
			shadow https://orders.staging.example.com
			sampling_rate 0.5
			diff_ignored_fields timestamp,updated_at
			diff_float_tolerance 0.01

			# Outbound connection-pool tuning (defaults: 100/10/100/90s)
			http_client {
				max_idle_conns 200
				max_idle_conns_per_host 20
				max_conns_per_host 200
				idle_conn_timeout 60s
			}
		}
	}

	# Non-shadowed routes — proxy directly to production
	route /* {
		reverse_proxy https://api.production.example.com
	}
}
