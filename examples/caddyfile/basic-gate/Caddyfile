{
	admin off
	auto_https off
}

# Basic gate configuration
:8080 {
	# Define routes that should be shadowed
	route /api/* {
		# Configure mroki_gate for this route
		mroki_gate {
			# Live backend (production)
			live https://api.production.example.com

			# Shadow backend (canary/staging)
			shadow https://api.shadow.example.com
		}
	}

	# Regular proxy for non-shadowed routes
	route /* {
		reverse_proxy https://api.production.example.com
	}
}
